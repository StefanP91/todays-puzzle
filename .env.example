# Admin panel (set in Netlify → Site settings → Environment variables)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password
ADMIN_JWT_SECRET=generate-a-long-random-string-here

# Google Analytics 4 (public — baked into client bundle at build time)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook App ID (for fb:app_id meta tag and share dialog)
VITE_FACEBOOK_APP_ID=1234567890123456

# Facebook Page insights in admin panel (server-side only — do not expose the token)
FACEBOOK_PAGE_ID=123456789012345
FACEBOOK_PAGE_ACCESS_TOKEN=your-long-lived-page-access-token
